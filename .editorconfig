# EditorConfig is awesome: https://editorconfig.org
root = true

# Defaults
[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

# Batch Files
[*.{cmd,bat}]
end_of_line = crlf

[*.xml]
indent_size = 2

[*.yaml]
indent_size = 2
